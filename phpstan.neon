includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - vendor/pestphp/pest/extension.neon
    - vendor/pestphp/pest/phpstan-pest-extension.neon

parameters:
    paths:
        - app
        - routes
        - database
        - tests

    level: 5
    parseModelCastsMethod: true
    stubFiles:
        - phpstan-pest.stub
